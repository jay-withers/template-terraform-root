# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable definition files that may contain secrets
*.tfvars
*.tfvars.json

# CLI configuration and override files
.terraformrc
terraform.rc
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Provider lock file — not committed for a reusable module (consumers generate
# their own); commit it instead if you repurpose this repo as a root config.
.terraform.lock.hcl

# Saved plan output
*.tfplan
